# ========================================
# JuriSight Production Environment Template
# ========================================
# Usage: Copy this file to `.env` on your production server and fill in the actual values.

# --- Core Setup ---
NODE_ENV="production"
PORT=3001

# --- Security (Must be changed!) ---
# Generate these using `openssl rand -base64 32`
JWT_SECRET="generate-a-strong-secret-here"
JWT_REFRESH_SECRET="generate-another-strong-secret-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# --- URLs & CORS ---
# Must exactly match the domain the frontend is hosted on to allow requests
CORS_ORIGIN="https://your-frontend-domain.com"
# Used by Google OAuth for redirection
BACKEND_URL="https://api.your-domain.com"

# --- Frontend Build Variables ---
# Vite injects these during `npm run build:frontend`
VITE_API_URL="https://api.your-domain.com"
VITE_WS_URL="wss://api.your-domain.com"

# --- Database ---
# For Prisma connecting to Neon or your own PostgreSQL
DATABASE_URL="postgresql://user:password@host:port/database?sslmode=require"

# --- Redis ---
# If using a local Redis on the server, use 127.0.0.1, NOT localhost
# Localhost bypasses the queue logic in production
REDIS_URL="redis://127.0.0.1:6379"

# --- AI APIs ---
# At least Gemini or OpenAI is required
GEMINI_API_KEY="your-gemini-key"
OPENAI_API_KEY="your-openai-key"
GROQ_API_KEY="your-groq-key"

# --- Google OAuth (Required for Google Login) ---
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- File Storage ---
UPLOAD_PATH="./uploads"
MAX_FILE_SIZE="52428800"

# --- Logging ---
LOG_LEVEL="warn"
LOG_FILE="./logs/production.log"
